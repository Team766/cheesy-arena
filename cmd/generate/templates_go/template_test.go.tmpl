			"seq": func(n int) []int { return []int{0, 1, 2, 3} },
			"add": func(a, b int) int { return a + b },
		})
		_, err = tmpl.Parse(string(content))
		assert.NoError(t, err)

[[range .ScoringGroups]]		assert.Contains(t, string(content), "id=\"leftFinal[[camel .ID]]Points\"")
		assert.Contains(t, string(content), "id=\"rightFinal[[camel .ID]]Points\"")
[[end]][[range .Statuses]]		assert.Contains(t, string(content), "id=\"leftFinal[[camel .ID]]Points\"")
[[end]][[range .RankingPoints]]		assert.Contains(t, string(content), "id=\"leftFinal[[camel .ID]]RankingPoint\"")
[[end]]	}

	{
		refereePath := filepath.Join(templatesDir, "generated_referee_panel.html")

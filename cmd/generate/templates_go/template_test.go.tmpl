			"add":  func(a, b int) int { return a + b },
		})
		_, err = tmpl.Parse(string(content))
		assert.NoError(t, err)

[[range .ScoringCounts]][[$el := .]][[range .Phases]]		assert.Contains(t, string(content), "onclick=\"adjustCount('[[$el.ID]]', '[[.Phase]]', -1);\"")
		assert.Contains(t, string(content), "id=\"[[$el.ID]]-[[.Phase]]-count\"")
[[end]][[end]][[range .Statuses]][[if eq .Phase "auto"]][[if .IsBool]]		assert.Contains(t, string(content), "onclick=\"toggleBoolStatus('[[.ID]]', {{add $i -1}});\"")
[[else]]		assert.Contains(t, string(content), "onclick=\"cycleEnumStatus('[[.ID]]', {{add $i -1}});\"")
[[end]][[end]][[end]]	}

	{
		content, err := os.ReadFile(audiencePath)
		assert.NoError(t, err)
		tmpl := template.New("audience")
